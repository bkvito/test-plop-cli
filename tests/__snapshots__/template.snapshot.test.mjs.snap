  name: 'SnapshotSinglePickNormal',
  components: {
    SinglePickButtonGroup,
  },
  props: {
    user: {
      type: Object as PropType<SnapshotSinglePickNormalProps['user']>,
      required: false,
    },
  },
  setup(props) {
    const { selectedValue } = useSnapshotSinglePickNormal(props as SnapshotSinglePickNormalProps)

    return {
