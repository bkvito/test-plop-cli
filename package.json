{
  "name": "create-component-template-cli",
  "description": "create-vue-component-template-cli,A CLI tool for creating standardized Vue 3 + TypeScript + Sass public component templates.",
  "version": "1.0.4",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cctc": "bin/cli.mjs",
    "create-component-template-cli": "bin/cli.mjs"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:template:general:setup": "node bin/cli.mjs --name=VerifyGeneralSetup --rootPath=tmp-output/template-verify --templateType=general --vueTemplateType=setup --collisionStrategy=overwrite",
    "verify:template:general:normal": "node bin/cli.mjs --name=VerifyGeneralNormal --rootPath=tmp-output/template-verify --templateType=general --vueTemplateType=normal --collisionStrategy=overwrite",
    "verify:template:single-pick:setup": "node bin/cli.mjs --name=VerifySinglePickSetup --rootPath=tmp-output/template-verify --templateType=single-pick --vueTemplateType=setup --collisionStrategy=overwrite",
    "verify:template:single-pick:normal": "node bin/cli.mjs --name=VerifySinglePickNormal --rootPath=tmp-output/template-verify --templateType=single-pick --vueTemplateType=normal --collisionStrategy=overwrite",
    "verify:template:multiple-pick:setup": "node bin/cli.mjs --name=VerifyMultiplePickSetup --rootPath=tmp-output/template-verify --templateType=multiple-pick --vueTemplateType=setup --collisionStrategy=overwrite",
    "verify:template:multiple-pick:normal": "node bin/cli.mjs --name=VerifyMultiplePickNormal --rootPath=tmp-output/template-verify --templateType=multiple-pick --vueTemplateType=normal --collisionStrategy=overwrite",
    "verify:template:check": "node scripts/verify-templates.mjs",
    "verify:template:all": "npm run verify:template:general:setup && npm run verify:template:general:normal && npm run verify:template:single-pick:setup && npm run verify:template:single-pick:normal && npm run verify:template:multiple-pick:setup && npm run verify:template:multiple-pick:normal && npm run verify:template:check"
  },
  "access": "public",
  "dependencies": {
    "@types/minimist": "^1.2.5",
    "change-case": "^5.4.4",
    "minimist": "^1.2.8",
    "plop": "^4.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "vitest": "^3.2.4"
  },
  "author": {
    "name": "young-man",
    "email": "2419445705@qq.com"
  },
  "package-info": {
    "branch": "agent-cli"
  }
}
